        ensure_attachment_entity(conn, row['entity_type'], row['entity_ref'])
    print(json.dumps(dict(row), indent=2, ensure_ascii=False))


def cmd_attach_remove(args):
    with connect() as conn:
        init_db(conn)
        row = conn.execute('SELECT * FROM attachments WHERE id=?', (args.attachment_id,)).fetchone()
