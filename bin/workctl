def cmd_task_board(args):
    with connect() as conn:
        init_db(conn)
        require_project(conn, args.project)
        q = """
        SELECT id, title, status, priority, board, column_key, wip_order, assignee, due_at, updated_at
        FROM tasks
        WHERE project_id = ?
        """
        params = [args.project]
        if args.board:
            q += ' AND board = ?'
            params.append(args.board)
        if not args.include_archived:
            q += " AND status != 'archived'"
        q += " ORDER BY COALESCE(board,''), COALESCE(column_key,''), COALESCE(wip_order, sort_order), id"
        rows = [dict(r) for r in conn.execute(q, params)]
    grouped = {}
    for r in rows:
        board = r.get('board') or '(no board)'
        col = r.get('column_key') or '(no column)'
        grouped.setdefault(board, {}).setdefault(col, []).append(r)
    print(json.dumps(grouped, indent=2, ensure_ascii=False))


def cmd_task_update(args):
    with connect() as conn:
        init_db(conn)
        task = require_task(conn, args.task)
        title = args.title if args.title is not None else task['title']
        description = args.description if args.description is not None else task['description']
        priority = args.priority if args.priority is not None else task['priority']
        assignee = args.assignee if args.assignee is not None else task['assignee']
        due_at = args.due_at if args.due_at is not None else task['due_at']
        parent_task_id = args.parent_task_id if args.parent_task_id is not None else task['parent_task_id']
        board = args.board if args.board is not None else task['board']
        column_key = args.column_key if args.column_key is not None else task['column_key']
        wip_order = args.wip_order if args.wip_order is not None else task['wip_order']
        sort_order = args.sort_order if args.sort_order is not None else task['sort_order']
        if parent_task_id is not None:
            if int(parent_task_id) == int(args.task):
                raise ValueError('task cannot be its own parent')
            require_task(conn, int(parent_task_id))
        conn.execute(
            'UPDATE tasks SET parent_task_id=?, title=?, description=?, priority=?, assignee=?, due_at=?, board=?, column_key=?, wip_order=?, sort_order=? WHERE id=?',
            (parent_task_id, title, description, priority, assignee, due_at, board, column_key, wip_order, sort_order, args.task),
        )
        if args.note:
            add_task_system_comment(conn, args.task, args.note)
        conn.commit()
    print(json.dumps({'id': args.task, 'title': title, 'priority': priority, 'board': board, 'column_key': column_key}))


def cmd_task_move(args):
    with connect() as conn:
        init_db(conn)
        task = require_task(conn, args.task)
        board = args.board if args.board is not None else task['board']
        column_key = args.column_key if args.column_key is not None else task['column_key']
        wip_order = args.wip_order if args.wip_order is not None else task['wip_order']
        status = args.status if args.status is not None else task['status']
        started_at, completed_at = apply_task_status_transition(task, status, args.completed_at)
        conn.execute(
            'UPDATE tasks SET board=?, column_key=?, wip_order=?, status=?, started_at=?, completed_at=? WHERE id=?',
            (board, column_key, wip_order, status, started_at, completed_at, args.task),
        )
        if args.note:
            add_task_system_comment(conn, args.task, args.note)
        conn.commit()
    print(json.dumps({'id': args.task, 'board': board, 'column_key': column_key, 'wip_order': wip_order, 'status': status}))




