        conn.execute('UPDATE tasks SET status=?, started_at=?, completed_at=?, board=?, column_key=?, wip_order=? WHERE id=?', (args.status, started_at, completed_at, board, column_key, wip_order, args.task))
        if args.note:
            add_task_system_comment(conn, args.task, args.note)
        conn.commit()
    print(json.dumps({'id': args.task, 'old_status': task['status'], 'new_status': args.status}))


