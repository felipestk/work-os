def cmd_search(args):
    with connect() as conn:
        init_db(conn)
        like = f"%{args.keyword}%"
        rows = []
        for r in conn.execute('SELECT customer_code AS ref, name AS label, "customer" AS entity, updated_at AS at FROM customers WHERE name LIKE ? OR notes LIKE ? LIMIT 20', (like, like)):
            rows.append(dict(r))
        for r in conn.execute('SELECT id AS ref, title AS label, "project" AS entity, updated_at AS at FROM projects WHERE title LIKE ? OR objective LIKE ? OR summary LIKE ? LIMIT 20', (like, like, like)):
            rows.append(dict(r))
        for r in conn.execute('SELECT offer_code AS ref, title AS label, "offer" AS entity, updated_at AS at FROM offers WHERE title LIKE ? OR summary LIKE ? OR assumptions LIKE ? LIMIT 20', (like, like, like)):
            rows.append(dict(r))
        for r in conn.execute('SELECT a.id AS ref, COALESCE(a.subject, substr(a.body,1,80)) AS label, "activity" AS entity, a.happened_at AS at FROM activities a WHERE a.subject LIKE ? OR a.body LIKE ? LIMIT 20', (like, like)):
            rows.append(dict(r))
        for r in conn.execute('SELECT t.id AS ref, t.title AS label, "task" AS entity, t.updated_at AS at FROM tasks t WHERE t.title LIKE ? OR t.description LIKE ? OR t.board LIKE ? OR t.column_key LIKE ? LIMIT 20', (like, like, like, like)):
            rows.append(dict(r))
    rows.sort(key=lambda x: (x.get('at') or ''), reverse=True)
    print_rows(rows[:args.limit], table=args.table)


def build_parser():
    p = argparse.ArgumentParser(description='Work OS CLI scaffold')
    sub = p.add_subparsers(dest='cmd', required=True)

    sp = sub.add_parser('init')
    sp.set_defaults(func=cmd_init)

    sp = sub.add_parser('doctor')
    sp.set_defaults(func=cmd_doctor)

    sp = sub.add_parser('search')
    sp.add_argument('--keyword', required=True)
    sp.add_argument('--limit', type=int, default=50)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_search)

    customer = sub.add_parser('customer')
    csub = customer.add_subparsers(dest='sub', required=True)
    sp = csub.add_parser('create')
    sp.add_argument('--type', required=True, choices=['company', 'private'])
    sp.add_argument('--name', required=True)
    sp.add_argument('--legal-name')
    sp.add_argument('--website')
    sp.add_argument('--industry')
    sp.add_argument('--country')
    sp.add_argument('--notes')
    sp.set_defaults(func=cmd_customer_create)

    sp = csub.add_parser('list')
    sp.add_argument('--keyword')
    sp.add_argument('--limit', type=int, default=50)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_customer_list)

    sp = csub.add_parser('show')
    sp.add_argument('--customer', required=True)
    sp.set_defaults(func=cmd_customer_show)

    contact = sub.add_parser('contact')
    ctsub = contact.add_subparsers(dest='sub', required=True)
    sp = ctsub.add_parser('add')
    sp.add_argument('--customer', required=True)
    sp.add_argument('--first-name')
    sp.add_argument('--last-name')
    sp.add_argument('--role')
    sp.add_argument('--email')
    sp.add_argument('--phone')
    sp.add_argument('--linkedin')
    sp.add_argument('--primary', action='store_true')
    sp.add_argument('--notes')
    sp.set_defaults(func=cmd_contact_add)

    sp = ctsub.add_parser('list')
    sp.add_argument('--customer', required=True)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_contact_list)

    project = sub.add_parser('project')
    psub = project.add_subparsers(dest='sub', required=True)
    sp = psub.add_parser('create')
    sp.add_argument('--customer', required=True)
    sp.add_argument('--title', required=True)
    sp.add_argument('--objective')
    sp.add_argument('--summary')
    sp.add_argument('--slug')
    sp.add_argument('--status', default='active', choices=['active', 'blocked', 'completed', 'archived'])
    sp.add_argument('--owner')
    sp.add_argument('--alias', action='append', default=[])
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_project_create)

    sp = psub.add_parser('list')
    sp.add_argument('--customer')
    sp.add_argument('--status', choices=['active', 'blocked', 'completed', 'archived'])
    sp.add_argument('--active', action='store_true')
    sp.add_argument('--task-status', choices=['todo', 'in_progress', 'blocked', 'done', 'cancelled', 'archived'])
    sp.add_argument('--has-open-tasks', action='store_true')
    sp.add_argument('--has-blocked-tasks', action='store_true')
    sp.add_argument('--include-archived-tasks', action='store_true')
    sp.add_argument('--limit', type=int, default=50)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_project_list)

    sp = psub.add_parser('show')
    sp.add_argument('--project', required=True)
    sp.add_argument('--include-tasks', action='store_true')
    sp.add_argument('--include-archived-tasks', action='store_true')
    sp.add_argument('--include-attachments', action='store_true')
    sp.set_defaults(func=cmd_project_show)

    sp = psub.add_parser('event')
    sp.add_argument('--project', required=True)
    sp.add_argument('--type', default='note', choices=['created', 'updated', 'note', 'blocked', 'completed', 'reopened', 'status_changed', 'artifact_added', 'subagent_handoff'])
    sp.add_argument('--note', required=True)
    sp.add_argument('--metadata')
    sp.set_defaults(func=cmd_project_event)

    sp = psub.add_parser('status')
    sp.add_argument('--project', required=True)
    sp.add_argument('--status', required=True, choices=['active', 'blocked', 'completed', 'archived'])
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_project_status)

    activity = sub.add_parser('activity')
    asub = activity.add_subparsers(dest='sub', required=True)
    sp = asub.add_parser('add')
    sp.add_argument('--customer', required=True)
    sp.add_argument('--project')
    sp.add_argument('--offer')
    sp.add_argument('--contact-id', type=int)
    sp.add_argument('--type', required=True, choices=['note', 'email', 'call', 'meeting', 'whatsapp', 'telegram', 'decision', 'summary', 'other'])
    sp.add_argument('--direction', choices=['inbound', 'outbound', 'internal'])
    sp.add_argument('--subject')
    sp.add_argument('--body', required=True)
    sp.add_argument('--source-ref')
    sp.add_argument('--thread-id')
    sp.add_argument('--message-id')
    sp.add_argument('--happened-at')
    sp.set_defaults(func=cmd_activity_add)

    sp = asub.add_parser('list')
    sp.add_argument('--customer')
    sp.add_argument('--project')
    sp.add_argument('--offer')
    sp.add_argument('--type')
    sp.add_argument('--limit', type=int, default=50)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_activity_list)


    attach = sub.add_parser('attach')
    atsub = attach.add_subparsers(dest='sub', required=True)
    sp = atsub.add_parser('add')
    sp.add_argument('--entity-type', required=True, choices=['activity', 'offer', 'customer', 'contact', 'project', 'task'])
    sp.add_argument('--entity-ref', required=True)
    sp.add_argument('--file', required=True)
    sp.add_argument('--mime-type')
    sp.set_defaults(func=cmd_attach_add)

    sp = atsub.add_parser('list')
    sp.add_argument('--entity-type', required=True, choices=['activity', 'offer', 'customer', 'contact', 'project', 'task'])
    sp.add_argument('--entity-ref', required=True)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_attach_list)

    sp = atsub.add_parser('show')
    sp.add_argument('--attachment-id', type=int, required=True)
    sp.set_defaults(func=cmd_attach_show)

    sp = atsub.add_parser('remove')
    sp.add_argument('--attachment-id', type=int, required=True)
    sp.set_defaults(func=cmd_attach_remove)

    task = sub.add_parser('task')
    tsub = task.add_subparsers(dest='sub', required=True)

    sp = tsub.add_parser('create')
    sp.add_argument('--project', required=True)
    sp.add_argument('--parent-task-id', type=int)
    sp.add_argument('--title', required=True)
    sp.add_argument('--description')
    sp.add_argument('--status', default='todo', choices=['todo', 'in_progress', 'blocked', 'done', 'cancelled', 'archived'])
    sp.add_argument('--priority', choices=['low', 'medium', 'high', 'urgent'])
    sp.add_argument('--board')
    sp.add_argument('--column-key')
    sp.add_argument('--wip-order', type=float)
    sp.add_argument('--sort-order', type=int, default=0)
    sp.add_argument('--due-at')
    sp.add_argument('--started-at')
    sp.add_argument('--completed-at')
    sp.add_argument('--assignee')
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_task_create)

    sp = tsub.add_parser('list')
    sp.add_argument('--project')
    sp.add_argument('--status', choices=['todo', 'in_progress', 'blocked', 'done', 'cancelled', 'archived'])
    sp.add_argument('--board')
    sp.add_argument('--column-key')
    sp.add_argument('--assignee')
    sp.add_argument('--parent-task-id', type=int)
    sp.add_argument('--due-before')
    sp.add_argument('--due-after')
    sp.add_argument('--include-archived', action='store_true')
    sp.add_argument('--limit', type=int, default=50)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_task_list)

    sp = tsub.add_parser('show')
    sp.add_argument('--task', type=int, required=True)
    sp.set_defaults(func=cmd_task_show)

    sp = tsub.add_parser('board')
    sp.add_argument('--project', required=True)
    sp.add_argument('--board')
    sp.add_argument('--include-archived', action='store_true')
    sp.set_defaults(func=cmd_task_board)

    sp = tsub.add_parser('update')
    sp.add_argument('--task', type=int, required=True)
    sp.add_argument('--parent-task-id', type=int)
    sp.add_argument('--title')
    sp.add_argument('--description')
    sp.add_argument('--priority', choices=['low', 'medium', 'high', 'urgent'])
    sp.add_argument('--assignee')
    sp.add_argument('--due-at')
    sp.add_argument('--board')
    sp.add_argument('--column-key')
    sp.add_argument('--wip-order', type=float)
    sp.add_argument('--sort-order', type=int)
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_task_update)

    sp = tsub.add_parser('move')
    sp.add_argument('--task', type=int, required=True)
    sp.add_argument('--board')
    sp.add_argument('--column-key')
    sp.add_argument('--wip-order', type=float)
    sp.add_argument('--status', choices=['todo', 'in_progress', 'blocked', 'done', 'cancelled', 'archived'])
    sp.add_argument('--completed-at')
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_task_move)

    sp = tsub.add_parser('archive')
    sp.add_argument('--task', type=int, required=True)
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_task_archive)

    sp = tsub.add_parser('unarchive')
    sp.add_argument('--task', type=int, required=True)
    sp.add_argument('--status', choices=['todo', 'in_progress', 'blocked', 'done', 'cancelled'])
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_task_unarchive)

    sp = tsub.add_parser('status')
    sp.add_argument('--task', type=int, required=True)
    sp.add_argument('--status', required=True, choices=['todo', 'in_progress', 'blocked', 'done', 'cancelled', 'archived'])
    sp.add_argument('--completed-at')
    sp.add_argument('--board')
    sp.add_argument('--column-key')
    sp.add_argument('--wip-order', type=float)
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_task_status)

    comment = tsub.add_parser('comment')
    csub = comment.add_subparsers(dest='comment_sub', required=True)
    sp = csub.add_parser('add')
    sp.add_argument('--task', type=int, required=True)
    sp.add_argument('--body', required=True)
    sp.add_argument('--author')
    sp.add_argument('--comment-type', default='comment', choices=['comment', 'system'])
    sp.set_defaults(func=cmd_task_comment_add)

    sp = csub.add_parser('list')
    sp.add_argument('--task', type=int, required=True)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_task_comment_list)

    sp = csub.add_parser('show')
    sp.add_argument('--comment-id', type=int, required=True)
    sp.set_defaults(func=cmd_task_comment_show)

    sp = csub.add_parser('edit')
    sp.add_argument('--comment-id', type=int, required=True)
    sp.add_argument('--body')
    sp.add_argument('--author')
    sp.add_argument('--comment-type', choices=['comment', 'system'])
    sp.set_defaults(func=cmd_task_comment_edit)

    offer = sub.add_parser('offer')
    osub = offer.add_subparsers(dest='sub', required=True)
    sp = osub.add_parser('create')
    sp.add_argument('--customer', required=True)
    sp.add_argument('--project')
    sp.add_argument('--contact-id', type=int)
    sp.add_argument('--title', required=True)
    sp.add_argument('--currency', default='EUR')
    sp.add_argument('--subtotal', type=float)
    sp.add_argument('--tax', type=float)
    sp.add_argument('--total', type=float)
    sp.add_argument('--valid-until')
    sp.add_argument('--summary')
    sp.add_argument('--assumptions')
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_offer_create)

    sp = osub.add_parser('list')
    sp.add_argument('--customer')
    sp.add_argument('--project')
    sp.add_argument('--status')
    sp.add_argument('--limit', type=int, default=50)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_offer_list)

    sp = osub.add_parser('show')
    sp.add_argument('--offer', required=True)
    sp.add_argument('--version', type=int)
    sp.set_defaults(func=cmd_offer_show)

    sp = osub.add_parser('versions')
    sp.add_argument('--offer', required=True)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_offer_versions)

    sp = osub.add_parser('status')
    sp.add_argument('--offer', required=True)
    sp.add_argument('--status', required=True, choices=['draft', 'sent', 'accepted', 'rejected', 'expired', 'revised', 'archived'])
    sp.add_argument('--decision-at')
    sp.set_defaults(func=cmd_offer_status)

    sp = osub.add_parser('revise')
    sp.add_argument('--offer', required=True)
    sp.add_argument('--title')
    sp.add_argument('--currency')
    sp.add_argument('--subtotal', type=float)
    sp.add_argument('--tax', type=float)
    sp.add_argument('--total', type=float)
    sp.add_argument('--valid-until')
    sp.add_argument('--summary')
    sp.add_argument('--assumptions')
    sp.add_argument('--note')
    sp.set_defaults(func=cmd_offer_revise)

    item = osub.add_parser('item')
    isub = item.add_subparsers(dest='item_sub', required=True)

    sp = isub.add_parser('add')
    sp.add_argument('--offer', required=True)
    sp.add_argument('--version', type=int)
    sp.add_argument('--billing-type', required=True, choices=['one_time', 'recurring'])
    sp.add_argument('--name', required=True)
    sp.add_argument('--description')
    sp.add_argument('--quantity', type=float, default=1.0)
    sp.add_argument('--unit')
    sp.add_argument('--unit-price', type=float, required=True)
    sp.add_argument('--tax-rate', type=float)
    sp.add_argument('--currency')
    sp.add_argument('--sort-order', type=int, default=0)
    sp.set_defaults(func=cmd_offer_item_add)

    sp = isub.add_parser('list')
    sp.add_argument('--offer', required=True)
    sp.add_argument('--version', type=int)
    sp.add_argument('--table', action='store_true')
    sp.set_defaults(func=cmd_offer_item_list)

    sp = isub.add_parser('update')
    sp.add_argument('--item-id', type=int, required=True)
    sp.add_argument('--billing-type', choices=['one_time', 'recurring'])
    sp.add_argument('--name')
    sp.add_argument('--description')
    sp.add_argument('--quantity', type=float)
    sp.add_argument('--unit')
    sp.add_argument('--unit-price', type=float)
    sp.add_argument('--tax-rate', type=float)
    sp.add_argument('--sort-order', type=int)
    sp.set_defaults(func=cmd_offer_item_update)

    sp = isub.add_parser('remove')
    sp.add_argument('--item-id', type=int, required=True)
    sp.set_defaults(func=cmd_offer_item_remove)

    totals = osub.add_parser('totals')
    tsub = totals.add_subparsers(dest='totals_sub', required=True)
    sp = tsub.add_parser('recalc')
    sp.add_argument('--offer', required=True)
    sp.add_argument('--version', type=int)
    sp.set_defaults(func=cmd_offer_totals_recalc)

    return p


def main():
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except Exception as e:
        parser.exit(1, f'ERROR: {e}\n')


if __name__ == '__main__':
    main()
