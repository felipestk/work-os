def cmd_attach_add(args):
    with connect() as conn:
        init_db(conn)
        ensure_attachment_entity(conn, args.entity_type, args.entity_ref)
        file_path = Path(args.file).expanduser().resolve()
        if not file_path.exists() or not file_path.is_file():
            raise ValueError(f"File not found: {file_path}")
        checksum = file_checksum(file_path)
        cur = conn.execute(
            'INSERT INTO attachments(entity_type, entity_ref, file_path, mime_type, checksum) VALUES (?, ?, ?, ?, ?)',
            (args.entity_type, str(args.entity_ref), str(file_path), args.mime_type, checksum),
        )
        conn.commit()
    print(json.dumps({'id': cur.lastrowid, 'entity_type': args.entity_type, 'entity_ref': str(args.entity_ref), 'file_path': str(file_path), 'checksum': checksum}))


def cmd_attach_list(args):
    with connect() as conn:
        init_db(conn)
        ensure_attachment_entity(conn, args.entity_type, args.entity_ref)
        rows = [dict(r) for r in conn.execute(
            'SELECT id, entity_type, entity_ref, file_path, mime_type, checksum, created_at FROM attachments WHERE entity_type=? AND entity_ref=? ORDER BY created_at DESC, id DESC',
            (args.entity_type, str(args.entity_ref)),
        )]
    print_rows(rows, table=args.table)


def cmd_attach_show(args):
