    print_rows(rows, table=args.table)


def cmd_project_create(args):
    with connect() as conn:
        init_db(conn)
        customer = require_customer(conn, args.customer)
        project_id = next_project_id(conn)
        slug = slugify(args.slug or args.title)
        folder = PROJECTS_ROOT / f'{project_id}-{slug}'
        folder.mkdir(parents=True, exist_ok=True)
        conn.execute(
            """
            INSERT INTO projects(id, slug, customer_id, title, status, objective, summary, folder_path, owner)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (project_id, slug, customer['id'], args.title, args.status, args.objective, args.summary, str(folder), args.owner),
        )
        conn.execute(
            "INSERT INTO project_events(project_id, event_type, note, metadata_json) VALUES (?, 'created', ?, ?)",
            (project_id, args.note or 'Project created', json.dumps({'actor': 'workctl', 'timestamp': now_iso()})),
        )
        for alias in args.alias:
            conn.execute(
                "INSERT OR IGNORE INTO aliases(entity_type, entity_ref, alias, alias_type) VALUES ('project', ?, ?, 'keyword')",
                (project_id, alias),
            )
        conn.commit()
    print(json.dumps({'id': project_id, 'title': args.title, 'customer': customer['name'], 'status': args.status, 'folder': str(folder)}))


def cmd_project_list(args):
    with connect() as conn:
        init_db(conn)
        q = """
        SELECT p.id, p.title, c.name AS customer, p.status, p.updated_at, p.folder_path,
               COUNT(t.id) AS task_count,
               SUM(CASE WHEN t.status = 'todo' THEN 1 ELSE 0 END) AS todo_tasks,
               SUM(CASE WHEN t.status = 'in_progress' THEN 1 ELSE 0 END) AS in_progress_tasks,
               SUM(CASE WHEN t.status = 'blocked' THEN 1 ELSE 0 END) AS blocked_tasks,
               SUM(CASE WHEN t.status = 'done' THEN 1 ELSE 0 END) AS done_tasks,
               SUM(CASE WHEN t.status = 'archived' THEN 1 ELSE 0 END) AS archived_tasks
        FROM projects p
        JOIN customers c ON c.id = p.customer_id
        LEFT JOIN tasks t ON t.project_id = p.id
        """
        params = []
        where = []
        having = []
        if args.customer:
            where.append('(c.customer_code = ? OR c.name = ?)')
            params += [args.customer, args.customer]
        if args.active:
            where.append("p.status IN ('active','blocked')")
        if args.status:
            where.append('p.status = ?')
            params.append(args.status)
        if not args.include_archived_tasks:
            where.append("(t.id IS NULL OR t.status != 'archived')")
        if args.task_status:
            having.append("SUM(CASE WHEN t.status = ? THEN 1 ELSE 0 END) > 0")
            params.append(args.task_status)
        if args.has_open_tasks:
            having.append("SUM(CASE WHEN t.status IN ('todo','in_progress','blocked') THEN 1 ELSE 0 END) > 0")
        if args.has_blocked_tasks:
            having.append("SUM(CASE WHEN t.status = 'blocked' THEN 1 ELSE 0 END) > 0")
        if where:
            q += ' WHERE ' + ' AND '.join(where)
        q += ' GROUP BY p.id, p.title, c.name, p.status, p.updated_at, p.folder_path'
        if having:
            q += ' HAVING ' + ' AND '.join(having)
        q += ' ORDER BY p.updated_at DESC LIMIT ?'
        params.append(args.limit)
        rows = [dict(r) for r in conn.execute(q, params)]
    print_rows(rows, table=args.table)


def cmd_project_show(args):
    with connect() as conn:
        init_db(conn)
        row = require_project(conn, args.project)
        out = dict(row)
        if args.include_tasks:
            q = "SELECT id, parent_task_id, title, status, priority, board, column_key, wip_order, assignee, due_at, updated_at FROM tasks WHERE project_id=?"
            params = [args.project]
            if not args.include_archived_tasks:
                q += " AND status != 'archived'"
            q += " ORDER BY COALESCE(board,''), COALESCE(column_key,''), COALESCE(wip_order, sort_order), id"
            out['tasks'] = [dict(r) for r in conn.execute(q, params)]
        if args.include_attachments:
            out['attachments'] = [dict(r) for r in conn.execute(
                "SELECT id, file_path, mime_type, checksum, created_at FROM attachments WHERE entity_type='project' AND entity_ref=? ORDER BY created_at ASC, id ASC",
                (args.project,),
            )]
    print(json.dumps(out, indent=2, ensure_ascii=False))


def cmd_project_event(args):
    with connect() as conn:
        init_db(conn)
        require_project(conn, args.project)
        metadata = json.loads(args.metadata) if args.metadata else {}
        metadata.setdefault('actor', 'workctl')
        conn.execute(
            'INSERT INTO project_events(project_id, event_type, note, metadata_json) VALUES (?, ?, ?, ?)',
            (args.project, args.type, args.note, json.dumps(metadata)),
        )
        conn.commit()
    print(json.dumps({'ok': True, 'project': args.project, 'type': args.type}))


def cmd_project_status(args):
    with connect() as conn:
        init_db(conn)
        project = require_project(conn, args.project)
        conn.execute('UPDATE projects SET status = ? WHERE id = ?', (args.status, args.project))
        conn.execute(
            "INSERT INTO project_events(project_id, event_type, note, metadata_json) VALUES (?, 'status_changed', ?, ?)",
            (args.project, args.note or f"Status set to {args.status}", json.dumps({'old_status': project['status'], 'new_status': args.status, 'actor': 'workctl'})),
        )
        conn.commit()
    print(json.dumps({'id': args.project, 'old_status': project['status'], 'new_status': args.status}))


def cmd_activity_add(args):
    with connect() as conn:
        init_db(conn)
        customer = require_customer(conn, args.customer)
        if args.project:
            require_project(conn, args.project)
        offer_id = None
        if args.offer:
            offer = require_offer(conn, args.offer)
            offer_id = offer['id']
        happened_at = args.happened_at or now_iso()
        dedup_hash = compute_dedup_hash(customer['id'], args.project, args.offer, args.type, args.direction, args.subject, args.body, args.source_ref, args.message_id, args.thread_id, happened_at)
        cur = conn.execute(
            """
            INSERT OR IGNORE INTO activities(customer_id, project_id, offer_id, contact_id, activity_type, direction, subject, body, source_ref, thread_id, message_id, dedup_hash, happened_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (customer['id'], args.project, offer_id, args.contact_id, args.type, args.direction, args.subject, args.body, args.source_ref, args.thread_id, args.message_id, dedup_hash, happened_at),
        )
        conn.commit()
    if cur.rowcount == 0:
        print(json.dumps({'ok': True, 'duplicate': True}))
    else:
        print(json.dumps({'id': cur.lastrowid, 'customer': customer['name'], 'type': args.type}))


def cmd_activity_list(args):
    with connect() as conn:
        init_db(conn)
        q = """
        SELECT a.id, c.name AS customer, a.project_id, o.offer_code, a.activity_type, a.direction, a.subject, a.happened_at
        FROM activities a
        JOIN customers c ON c.id = a.customer_id
        LEFT JOIN offers o ON o.id = a.offer_id
        """
        where = []
        params = []
        if args.customer:
            where.append('(c.customer_code = ? OR c.name = ?)')
            params += [args.customer, args.customer]
        if args.project:
            where.append('a.project_id = ?')
            params.append(args.project)
        if args.offer:
            where.append('o.offer_code = ?')
            params.append(args.offer)
        if args.type:
            where.append('a.activity_type = ?')
            params.append(args.type)
        if where:
            q += ' WHERE ' + ' AND '.join(where)
        q += ' ORDER BY a.happened_at DESC LIMIT ?'
        params.append(args.limit)
        rows = [dict(r) for r in conn.execute(q, params)]
    print_rows(rows, table=args.table)


def make_offer_snapshot(conn, offer_id, version_no):
    offer = conn.execute('SELECT * FROM offers WHERE id=?', (offer_id,)).fetchone()
    items = [dict(r) for r in conn.execute(
        'SELECT billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order FROM offer_line_items WHERE offer_id=? AND version_no=? ORDER BY sort_order, id',
        (offer_id, version_no),
    )]
    return {
        'offer_code': offer['offer_code'],
        'title': offer['title'],
        'status': offer['status'],
        'currency': offer['currency'],
        'amount_subtotal': offer['amount_subtotal'],
        'amount_tax': offer['amount_tax'],
        'amount_total': offer['amount_total'],
        'sent_at': offer['sent_at'],
        'valid_until': offer['valid_until'],
        'decision_at': offer['decision_at'],
        'summary': offer['summary'],
        'assumptions': offer['assumptions'],
        'line_items': items,
    }


def write_offer_version(conn, offer_id, version_no, summary):
    conn.execute(
        'INSERT INTO offer_versions(offer_id, version_no, change_summary, snapshot_json) VALUES (?, ?, ?, ?)',
        (offer_id, version_no, summary, json.dumps(make_offer_snapshot(conn, offer_id, version_no), ensure_ascii=False)),
    )


def recalc_offer_totals(conn, offer_id, version_no):
    row = conn.execute(
        'SELECT COALESCE(SUM(line_subtotal),0) AS subtotal, COALESCE(SUM(line_tax),0) AS tax, COALESCE(SUM(line_total),0) AS total FROM offer_line_items WHERE offer_id=? AND version_no=?',
        (offer_id, version_no),
    ).fetchone()
    subtotal = float(row['subtotal'])
    tax = float(row['tax'])
    total = float(row['total'])
    current = conn.execute('SELECT current_version_no FROM offers WHERE id=?', (offer_id,)).fetchone()
    if current and int(current['current_version_no']) == int(version_no):
        conn.execute('UPDATE offers SET amount_subtotal=?, amount_tax=?, amount_total=? WHERE id=?', (subtotal, tax, total, offer_id))
    return subtotal, tax, total


def cmd_offer_create(args):
    with connect() as conn:
        init_db(conn)
        customer = require_customer(conn, args.customer)
        if args.project:
            require_project(conn, args.project)
        cur = conn.execute(
            """
            INSERT INTO offers(offer_code, customer_id, project_id, contact_id, title, status, currency, amount_subtotal, amount_tax, amount_total, valid_until, summary, assumptions)
            VALUES ('PENDING', ?, ?, ?, ?, 'draft', ?, ?, ?, ?, ?, ?, ?)
            """,
            (customer['id'], args.project, args.contact_id, args.title, args.currency, args.subtotal, args.tax, args.total, args.valid_until, args.summary, args.assumptions),
        )
        offer_id = cur.lastrowid
        offer_code = encode_offer_code(offer_id)
        conn.execute('UPDATE offers SET offer_code = ? WHERE id = ?', (offer_code, offer_id))
        write_offer_version(conn, offer_id, 1, args.note or 'Initial version')
        conn.commit()
    print(json.dumps({'offer_code': offer_code, 'customer': customer['name'], 'project': args.project, 'version': 1}))


def cmd_offer_list(args):
    with connect() as conn:
        init_db(conn)
        q = """
        SELECT o.offer_code, c.name AS customer, o.project_id, o.title, o.status, o.currency, o.amount_total, o.current_version_no, o.updated_at
        FROM offers o JOIN customers c ON c.id = o.customer_id
        """
        where = []
        params = []
        if args.customer:
            where.append('(c.customer_code = ? OR c.name = ?)')
            params += [args.customer, args.customer]
        if args.project:
            where.append('o.project_id = ?')
            params.append(args.project)
        if args.status:
            where.append('o.status = ?')
            params.append(args.status)
        if where:
            q += ' WHERE ' + ' AND '.join(where)
        q += ' ORDER BY o.updated_at DESC LIMIT ?'
        params.append(args.limit)
        rows = [dict(r) for r in conn.execute(q, params)]
    print_rows(rows, table=args.table)


def cmd_offer_show(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        if args.version:
            row = conn.execute('SELECT version_no, change_summary, created_at, snapshot_json FROM offer_versions WHERE offer_id=? AND version_no=?', (offer['id'], args.version)).fetchone()
            if not row:
                raise ValueError('Version not found')
            out = dict(row)
            out['snapshot'] = json.loads(out.pop('snapshot_json'))
        else:
            out = dict(offer)
    print(json.dumps(out, indent=2, ensure_ascii=False))


def cmd_offer_versions(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        rows = [dict(r) for r in conn.execute('SELECT version_no, change_summary, created_at FROM offer_versions WHERE offer_id=? ORDER BY version_no DESC', (offer['id'],))]
    print_rows(rows, table=args.table)


def cmd_offer_status(args):
