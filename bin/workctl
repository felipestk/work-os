        conn.execute('UPDATE offers SET status=?, decision_at=? WHERE id=?', (args.status, args.decision_at, offer['id']))
        conn.commit()
    print(json.dumps({'offer': args.offer, 'status': args.status}))


def cmd_offer_revise(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        previous_version = int(offer['current_version_no'])
        new_version = previous_version + 1
        conn.execute(
            """
            UPDATE offers SET title=?, status='revised', currency=?, amount_subtotal=?, amount_tax=?, amount_total=?, valid_until=?, summary=?, assumptions=?, current_version_no=?
            WHERE id=?
            """,
            (
                args.title if args.title is not None else offer['title'],
                args.currency if args.currency is not None else offer['currency'],
                args.subtotal if args.subtotal is not None else offer['amount_subtotal'],
                args.tax if args.tax is not None else offer['amount_tax'],
                args.total if args.total is not None else offer['amount_total'],
                args.valid_until if args.valid_until is not None else offer['valid_until'],
                args.summary if args.summary is not None else offer['summary'],
                args.assumptions if args.assumptions is not None else offer['assumptions'],
                new_version,
                offer['id'],
            ),
        )
        prev_items = conn.execute('SELECT billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order FROM offer_line_items WHERE offer_id=? AND version_no=? ORDER BY sort_order, id', (offer['id'], previous_version)).fetchall()
        for item in prev_items:
            conn.execute(
                'INSERT INTO offer_line_items(offer_id, version_no, billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
                (offer['id'], new_version, item['billing_type'], item['name'], item['description'], item['quantity'], item['unit'], item['unit_price'], item['tax_rate'], item['line_subtotal'], item['line_tax'], item['line_total'], item['currency'], item['sort_order']),
            )
        recalc_offer_totals(conn, offer['id'], new_version)
        write_offer_version(conn, offer['id'], new_version, args.note or 'Offer revised')
        conn.commit()
    print(json.dumps({'offer': args.offer, 'version': new_version}))


def cmd_offer_item_add(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        version_no = args.version or int(offer['current_version_no'])
        subtotal, tax, total = calc_line_totals(args.quantity, args.unit_price, args.tax_rate)
        currency = args.currency or offer['currency']
        cur = conn.execute(
            'INSERT INTO offer_line_items(offer_id, version_no, billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
            (offer['id'], version_no, args.billing_type, args.name, args.description, args.quantity, args.unit, args.unit_price, args.tax_rate, subtotal, tax, total, currency, args.sort_order),
        )
        rs, rt, rg = recalc_offer_totals(conn, offer['id'], version_no)
        conn.commit()
    print(json.dumps({'ok': True, 'item_id': cur.lastrowid, 'offer': args.offer, 'version': version_no, 'line_total': total, 'offer_totals': {'subtotal': rs, 'tax': rt, 'total': rg}}))


def cmd_offer_item_list(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        version_no = args.version or int(offer['current_version_no'])
        rows = [dict(r) for r in conn.execute(
            'SELECT id, version_no, billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order FROM offer_line_items WHERE offer_id=? AND version_no=? ORDER BY billing_type, sort_order, id',
            (offer['id'], version_no),
        )]
    print_rows(rows, table=args.table)


def cmd_offer_item_update(args):
    with connect() as conn:
        init_db(conn)
        row = conn.execute('SELECT * FROM offer_line_items WHERE id=?', (args.item_id,)).fetchone()
        if not row:
            raise ValueError('Item not found')
        quantity = args.quantity if args.quantity is not None else row['quantity']
        unit_price = args.unit_price if args.unit_price is not None else row['unit_price']
        tax_rate = args.tax_rate if args.tax_rate is not None else row['tax_rate']
        subtotal, tax, total = calc_line_totals(float(quantity), float(unit_price), float(tax_rate) if tax_rate is not None else None)
        conn.execute(
            'UPDATE offer_line_items SET billing_type=?, name=?, description=?, quantity=?, unit=?, unit_price=?, tax_rate=?, line_subtotal=?, line_tax=?, line_total=?, sort_order=? WHERE id=?',
            (
                args.billing_type or row['billing_type'],
                args.name or row['name'],
                args.description if args.description is not None else row['description'],
                quantity,
                args.unit if args.unit is not None else row['unit'],
                unit_price,
                tax_rate,
                subtotal,
                tax,
                total,
                args.sort_order if args.sort_order is not None else row['sort_order'],
                args.item_id,
            ),
        )
        rs, rt, rg = recalc_offer_totals(conn, row['offer_id'], row['version_no'])
        conn.commit()
    print(json.dumps({'ok': True, 'item_id': args.item_id, 'line_total': total, 'offer_totals': {'subtotal': rs, 'tax': rt, 'total': rg}}))


def cmd_offer_item_remove(args):
    with connect() as conn:
        init_db(conn)
        row = conn.execute('SELECT offer_id, version_no FROM offer_line_items WHERE id=?', (args.item_id,)).fetchone()
        if not row:
            raise ValueError('Item not found')
        conn.execute('DELETE FROM offer_line_items WHERE id=?', (args.item_id,))
        rs, rt, rg = recalc_offer_totals(conn, row['offer_id'], row['version_no'])
        conn.commit()
    print(json.dumps({'ok': True, 'item_id': args.item_id, 'offer_totals': {'subtotal': rs, 'tax': rt, 'total': rg}}))


def cmd_offer_totals_recalc(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        version_no = args.version or int(offer['current_version_no'])
        rs, rt, rg = recalc_offer_totals(conn, offer['id'], version_no)
        conn.commit()
    print(json.dumps({'ok': True, 'offer': args.offer, 'version': version_no, 'subtotal': rs, 'tax': rt, 'total': rg}))




def cmd_task_create(args):
    with connect() as conn:
        init_db(conn)
        require_project(conn, args.project)
        if args.parent_task_id is not None:
            require_task(conn, args.parent_task_id)
        cur = conn.execute(
            """
            INSERT INTO tasks(project_id, parent_task_id, title, description, status, priority, board, column_key, wip_order, sort_order, due_at, started_at, completed_at, assignee)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (args.project, args.parent_task_id, args.title, args.description, args.status, args.priority, args.board, args.column_key, args.wip_order, args.sort_order, args.due_at, args.started_at, args.completed_at, args.assignee),
        )
        task_id = cur.lastrowid
        if args.note:
            add_task_system_comment(conn, task_id, args.note)
        conn.commit()
    print(json.dumps({'id': task_id, 'project': args.project, 'title': args.title, 'status': args.status}))


def cmd_task_list(args):
    with connect() as conn:
        init_db(conn)
        q = """
        SELECT t.id, t.project_id, t.parent_task_id, t.title, t.status, t.priority, t.board, t.column_key, t.wip_order, t.assignee, t.due_at, t.updated_at
        FROM tasks t
        """
        where = []
        params = []
        if args.project:
            require_project(conn, args.project)
            where.append('t.project_id = ?')
            params.append(args.project)
        if args.status:
            where.append('t.status = ?')
            params.append(args.status)
        elif not args.include_archived:
            where.append("t.status != 'archived'")
        if args.board:
            where.append('t.board = ?')
            params.append(args.board)
        if args.column_key:
            where.append('t.column_key = ?')
            params.append(args.column_key)
        if args.assignee:
            where.append('t.assignee = ?')
            params.append(args.assignee)
        if args.parent_task_id is not None:
            where.append('t.parent_task_id = ?')
            params.append(args.parent_task_id)
        if args.due_before:
            where.append('t.due_at IS NOT NULL AND t.due_at <= ?')
            params.append(args.due_before)
        if args.due_after:
            where.append('t.due_at IS NOT NULL AND t.due_at >= ?')
            params.append(args.due_after)
        if where:
            q += ' WHERE ' + ' AND '.join(where)
        q += " ORDER BY t.project_id, COALESCE(t.board, ''), COALESCE(t.column_key, ''), COALESCE(t.wip_order, t.sort_order), t.id LIMIT ?"
        params.append(args.limit)
        rows = [dict(r) for r in conn.execute(q, params)]
    print_rows(rows, table=args.table)


