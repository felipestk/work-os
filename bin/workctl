#!/usr/bin/env python3
import argparse
import hashlib
import json
import os
import re
import sqlite3
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
DEFAULT_WORKSPACE = Path(os.environ.get('OPENCLAW_WORKSPACE', str(Path.home() / '.openclaw' / 'workspace'))).expanduser()
DB_PATH = Path(os.environ.get('WORKCTL_DB_PATH', str(DEFAULT_WORKSPACE / 'ops' / 'workos' / 'workos.db'))).expanduser()
SCHEMA_PATH = Path(os.environ.get('WORKCTL_SCHEMA_PATH', str(ROOT / 'schema' / 'workos.sql'))).expanduser()
PROJECTS_ROOT = Path(os.environ.get('WORKCTL_PROJECTS_ROOT', str(DEFAULT_WORKSPACE / 'work' / 'projects'))).expanduser()
CUSTOMERS_ROOT = Path(os.environ.get('WORKCTL_CUSTOMERS_ROOT', str(DEFAULT_WORKSPACE / 'work' / 'customers'))).expanduser()
PROJECT_ID_RE = re.compile(r'^PR\d{4}$')

ALPHABET = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'
OFFER_SALT = 8731


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace('+00:00', 'Z')


def slugify(text: str) -> str:
    text = text.lower().strip()
    text = re.sub(r'[^a-z0-9]+', '-', text)
    text = re.sub(r'-+', '-', text).strip('-')
    return text or 'item'


def connect() -> sqlite3.Connection:
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute('PRAGMA foreign_keys=ON')
    return conn


def init_db(conn: sqlite3.Connection) -> None:
    PROJECTS_ROOT.mkdir(parents=True, exist_ok=True)
    CUSTOMERS_ROOT.mkdir(parents=True, exist_ok=True)
    conn.executescript(SCHEMA_PATH.read_text(encoding='utf-8'))
    conn.commit()


def print_rows(rows, table=False):
    if isinstance(rows, dict):
        rows = [rows]
    if not table:
        print(json.dumps(rows, indent=2, ensure_ascii=False))
        return
    if not rows:
        print('(no rows)')
        return
    cols = list(rows[0].keys())
    widths = {c: len(c) for c in cols}
    for r in rows:
        for c in cols:
            widths[c] = max(widths[c], len(str(r.get(c, ''))))
    print(' | '.join(c.ljust(widths[c]) for c in cols))
    print('-+-'.join('-' * widths[c] for c in cols))
    for r in rows:
        print(' | '.join(str(r.get(c, '')).ljust(widths[c]) for c in cols))


def next_customer_code(conn):
    row = conn.execute("SELECT customer_code FROM customers ORDER BY id DESC LIMIT 1").fetchone()
    if not row:
        return 'CUST0001'
    return f"CUST{int(row['customer_code'][4:]) + 1:04d}"


def next_project_id(conn):
    row = conn.execute("SELECT id FROM projects ORDER BY id DESC LIMIT 1").fetchone()
    if not row:
        return 'PR0001'
    return f"PR{int(row['id'][2:]) + 1:04d}"


def encode_offer_code(seq: int) -> str:
    n = (seq * 2654435761) ^ OFFER_SALT
    if n <= 0:
        n = seq + OFFER_SALT
    chars = []
    base = len(ALPHABET)
    while n > 0:
        n, r = divmod(n, base)
        chars.append(ALPHABET[r])
    code = ''.join(reversed(chars)) or 'A'
    return f"Q{code[-8:]:>8}".replace(' ', 'X')


def calc_line_totals(quantity: float, unit_price: float, tax_rate: float | None):
    if quantity <= 0:
        raise ValueError('quantity must be > 0')
    if unit_price < 0:
        raise ValueError('unit-price must be >= 0')
    if tax_rate is not None and tax_rate < 0:
        raise ValueError('tax-rate must be >= 0')
    subtotal = round(quantity * unit_price, 2)
    tax = round(subtotal * ((tax_rate or 0.0) / 100.0), 2)
    total = round(subtotal + tax, 2)
    return subtotal, tax, total


def compute_dedup_hash(*parts):
    key = '|'.join(str(p or '') for p in parts)
    return hashlib.sha256(key.encode('utf-8')).hexdigest()


def require_customer(conn, customer_ref):
    row = conn.execute(
        "SELECT * FROM customers WHERE customer_code = ? OR name = ?",
        (customer_ref, customer_ref),
    ).fetchone()
    if not row:
        raise ValueError(f"Unknown customer: {customer_ref}")
    return row


def require_project(conn, project_id):
    if not PROJECT_ID_RE.match(project_id):
        raise ValueError('project must match PR0001 format')
    row = conn.execute(
        "SELECT p.*, c.customer_code, c.name AS customer_name FROM projects p JOIN customers c ON c.id = p.customer_id WHERE p.id = ?",
        (project_id,),
    ).fetchone()
    if not row:
        raise ValueError(f"Unknown project: {project_id}")
    return row


def require_offer(conn, offer_ref):
    row = conn.execute(
        "SELECT o.*, c.name AS customer_name, p.title AS project_title FROM offers o JOIN customers c ON c.id=o.customer_id LEFT JOIN projects p ON p.id=o.project_id WHERE o.offer_code = ?",
        (offer_ref,),
    ).fetchone()
    if not row:
        raise ValueError(f"Unknown offer: {offer_ref}")
    return row


def cmd_init(_args):
    with connect() as conn:
        init_db(conn)
    print(json.dumps({'ok': True, 'db': str(DB_PATH), 'schema': str(SCHEMA_PATH), 'workspace': str(DEFAULT_WORKSPACE)}))


def cmd_doctor(_args):
    with connect() as conn:
        init_db(conn)
        counts = {
            'customers': conn.execute('SELECT COUNT(*) c FROM customers').fetchone()['c'],
            'contacts': conn.execute('SELECT COUNT(*) c FROM contacts').fetchone()['c'],
            'projects': conn.execute('SELECT COUNT(*) c FROM projects').fetchone()['c'],
            'project_events': conn.execute('SELECT COUNT(*) c FROM project_events').fetchone()['c'],
            'offers': conn.execute('SELECT COUNT(*) c FROM offers').fetchone()['c'],
            'offer_versions': conn.execute('SELECT COUNT(*) c FROM offer_versions').fetchone()['c'],
            'offer_line_items': conn.execute('SELECT COUNT(*) c FROM offer_line_items').fetchone()['c'],
            'activities': conn.execute('SELECT COUNT(*) c FROM activities').fetchone()['c'],
        }
    print(json.dumps({'ok': True, 'counts': counts, 'db': str(DB_PATH), 'projects_root': str(PROJECTS_ROOT), 'customers_root': str(CUSTOMERS_ROOT), 'workspace': str(DEFAULT_WORKSPACE)}, indent=2))


def cmd_customer_create(args):
    with connect() as conn:
        init_db(conn)
        customer_code = next_customer_code(conn)
        conn.execute(
            """
            INSERT INTO customers(customer_code, customer_type, name, legal_name, website, industry, country, notes)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (customer_code, args.type, args.name, args.legal_name, args.website, args.industry, args.country, args.notes),
        )
        (CUSTOMERS_ROOT / customer_code).mkdir(parents=True, exist_ok=True)
        conn.commit()
    print(json.dumps({'customer_code': customer_code, 'name': args.name, 'type': args.type}))


def cmd_customer_list(args):
    with connect() as conn:
        init_db(conn)
        q = 'SELECT customer_code, customer_type, name, status, updated_at FROM customers'
        params = []
        if args.keyword:
            q += ' WHERE name LIKE ? OR notes LIKE ?'
            k = f'%{args.keyword}%'
            params += [k, k]
        q += ' ORDER BY updated_at DESC LIMIT ?'
        params.append(args.limit)
        rows = [dict(r) for r in conn.execute(q, params)]
    print_rows(rows, table=args.table)


def cmd_customer_show(args):
    with connect() as conn:
        init_db(conn)
        row = require_customer(conn, args.customer)
    print(json.dumps(dict(row), indent=2, ensure_ascii=False))


def cmd_contact_add(args):
    with connect() as conn:
        init_db(conn)
        customer = require_customer(conn, args.customer)
        cur = conn.execute(
            """
            INSERT INTO contacts(customer_id, first_name, last_name, role, email, phone, linkedin, is_primary, notes)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (customer['id'], args.first_name, args.last_name, args.role, args.email, args.phone, args.linkedin, 1 if args.primary else 0, args.notes),
        )
        conn.commit()
    print(json.dumps({'id': cur.lastrowid, 'customer': customer['name']}))


def cmd_contact_list(args):
    with connect() as conn:
        init_db(conn)
        customer = require_customer(conn, args.customer)
        rows = [dict(r) for r in conn.execute(
            'SELECT id, first_name, last_name, role, email, phone, linkedin, is_primary FROM contacts WHERE customer_id=? ORDER BY is_primary DESC, id DESC',
            (customer['id'],),
        )]
    print_rows(rows, table=args.table)


def cmd_project_create(args):
    with connect() as conn:
        init_db(conn)
        customer = require_customer(conn, args.customer)
        project_id = next_project_id(conn)
        slug = slugify(args.slug or args.title)
        folder = PROJECTS_ROOT / f'{project_id}-{slug}'
        folder.mkdir(parents=True, exist_ok=True)
        conn.execute(
            """
            INSERT INTO projects(id, slug, customer_id, title, status, objective, summary, folder_path, owner)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (project_id, slug, customer['id'], args.title, args.status, args.objective, args.summary, str(folder), args.owner),
        )
        conn.execute(
            "INSERT INTO project_events(project_id, event_type, note, metadata_json) VALUES (?, 'created', ?, ?)",
            (project_id, args.note or 'Project created', json.dumps({'actor': 'workctl', 'timestamp': now_iso()})),
        )
        for alias in args.alias:
            conn.execute(
                "INSERT OR IGNORE INTO aliases(entity_type, entity_ref, alias, alias_type) VALUES ('project', ?, ?, 'keyword')",
                (project_id, alias),
            )
        conn.commit()
    print(json.dumps({'id': project_id, 'title': args.title, 'customer': customer['name'], 'status': args.status, 'folder': str(folder)}))


def cmd_project_list(args):
    with connect() as conn:
        init_db(conn)
        q = """
        SELECT p.id, p.title, c.name AS customer, p.status, p.updated_at, p.folder_path
        FROM projects p
        JOIN customers c ON c.id = p.customer_id
        """
        params = []
        where = []
        if args.customer:
            where.append('(c.customer_code = ? OR c.name = ?)')
            params += [args.customer, args.customer]
        if args.active:
            where.append("p.status IN ('active','blocked')")
        if where:
            q += ' WHERE ' + ' AND '.join(where)
        q += ' ORDER BY p.updated_at DESC LIMIT ?'
        params.append(args.limit)
        rows = [dict(r) for r in conn.execute(q, params)]
    print_rows(rows, table=args.table)


