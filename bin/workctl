def cmd_project_event(args):
    with connect() as conn:
        init_db(conn)
        require_project(conn, args.project)
        metadata = json.loads(args.metadata) if args.metadata else {}
        metadata.setdefault('actor', 'workctl')
        conn.execute(
            'INSERT INTO project_events(project_id, event_type, note, metadata_json) VALUES (?, ?, ?, ?)',
            (args.project, args.type, args.note, json.dumps(metadata)),
        )
        conn.commit()
    print(json.dumps({'ok': True, 'project': args.project, 'type': args.type}))


def cmd_project_status(args):
    with connect() as conn:
        init_db(conn)
        project = require_project(conn, args.project)
        conn.execute('UPDATE projects SET status = ? WHERE id = ?', (args.status, args.project))
        conn.execute(
            "INSERT INTO project_events(project_id, event_type, note, metadata_json) VALUES (?, 'status_changed', ?, ?)",
            (args.project, args.note or f"Status set to {args.status}", json.dumps({'old_status': project['status'], 'new_status': args.status, 'actor': 'workctl'})),
        )
        conn.commit()
    print(json.dumps({'id': args.project, 'old_status': project['status'], 'new_status': args.status}))


def cmd_activity_add(args):
    with connect() as conn:
        init_db(conn)
        customer = require_customer(conn, args.customer)
        if args.project:
            require_project(conn, args.project)
        offer_id = None
        if args.offer:
            offer = require_offer(conn, args.offer)
            offer_id = offer['id']
        happened_at = args.happened_at or now_iso()
        dedup_hash = compute_dedup_hash(customer['id'], args.project, args.offer, args.type, args.direction, args.subject, args.body, args.source_ref, args.message_id, args.thread_id, happened_at)
        cur = conn.execute(
            """
            INSERT OR IGNORE INTO activities(customer_id, project_id, offer_id, contact_id, activity_type, direction, subject, body, source_ref, thread_id, message_id, dedup_hash, happened_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (customer['id'], args.project, offer_id, args.contact_id, args.type, args.direction, args.subject, args.body, args.source_ref, args.thread_id, args.message_id, dedup_hash, happened_at),
        )
        conn.commit()
    if cur.rowcount == 0:
        print(json.dumps({'ok': True, 'duplicate': True}))
    else:
        print(json.dumps({'id': cur.lastrowid, 'customer': customer['name'], 'type': args.type}))


def cmd_activity_list(args):
    with connect() as conn:
        init_db(conn)
        q = """
        SELECT a.id, c.name AS customer, a.project_id, o.offer_code, a.activity_type, a.direction, a.subject, a.happened_at
        FROM activities a
        JOIN customers c ON c.id = a.customer_id
        LEFT JOIN offers o ON o.id = a.offer_id
        """
        where = []
        params = []
        if args.customer:
            where.append('(c.customer_code = ? OR c.name = ?)')
            params += [args.customer, args.customer]
        if args.project:
            where.append('a.project_id = ?')
            params.append(args.project)
        if args.offer:
            where.append('o.offer_code = ?')
            params.append(args.offer)
        if args.type:
            where.append('a.activity_type = ?')
            params.append(args.type)
        if where:
            q += ' WHERE ' + ' AND '.join(where)
        q += ' ORDER BY a.happened_at DESC LIMIT ?'
        params.append(args.limit)
        rows = [dict(r) for r in conn.execute(q, params)]
    print_rows(rows, table=args.table)


def make_offer_snapshot(conn, offer_id, version_no):
    offer = conn.execute('SELECT * FROM offers WHERE id=?', (offer_id,)).fetchone()
    items = [dict(r) for r in conn.execute(
        'SELECT billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order FROM offer_line_items WHERE offer_id=? AND version_no=? ORDER BY sort_order, id',
        (offer_id, version_no),
    )]
    return {
        'offer_code': offer['offer_code'],
        'title': offer['title'],
        'status': offer['status'],
        'currency': offer['currency'],
        'amount_subtotal': offer['amount_subtotal'],
        'amount_tax': offer['amount_tax'],
        'amount_total': offer['amount_total'],
        'sent_at': offer['sent_at'],
        'valid_until': offer['valid_until'],
        'decision_at': offer['decision_at'],
        'summary': offer['summary'],
        'assumptions': offer['assumptions'],
        'line_items': items,
    }


def write_offer_version(conn, offer_id, version_no, summary):
    conn.execute(
        'INSERT INTO offer_versions(offer_id, version_no, change_summary, snapshot_json) VALUES (?, ?, ?, ?)',
        (offer_id, version_no, summary, json.dumps(make_offer_snapshot(conn, offer_id, version_no), ensure_ascii=False)),
    )


def recalc_offer_totals(conn, offer_id, version_no):
    row = conn.execute(
        'SELECT COALESCE(SUM(line_subtotal),0) AS subtotal, COALESCE(SUM(line_tax),0) AS tax, COALESCE(SUM(line_total),0) AS total FROM offer_line_items WHERE offer_id=? AND version_no=?',
        (offer_id, version_no),
    ).fetchone()
    subtotal = float(row['subtotal'])
    tax = float(row['tax'])
    total = float(row['total'])
    current = conn.execute('SELECT current_version_no FROM offers WHERE id=?', (offer_id,)).fetchone()
    if current and int(current['current_version_no']) == int(version_no):
        conn.execute('UPDATE offers SET amount_subtotal=?, amount_tax=?, amount_total=? WHERE id=?', (subtotal, tax, total, offer_id))
    return subtotal, tax, total


def cmd_offer_create(args):
    with connect() as conn:
        init_db(conn)
        customer = require_customer(conn, args.customer)
        if args.project:
            require_project(conn, args.project)
        cur = conn.execute(
            """
            INSERT INTO offers(offer_code, customer_id, project_id, contact_id, title, status, currency, amount_subtotal, amount_tax, amount_total, valid_until, summary, assumptions)
            VALUES ('PENDING', ?, ?, ?, ?, 'draft', ?, ?, ?, ?, ?, ?, ?)
            """,
            (customer['id'], args.project, args.contact_id, args.title, args.currency, args.subtotal, args.tax, args.total, args.valid_until, args.summary, args.assumptions),
        )
        offer_id = cur.lastrowid
        offer_code = encode_offer_code(offer_id)
        conn.execute('UPDATE offers SET offer_code = ? WHERE id = ?', (offer_code, offer_id))
        write_offer_version(conn, offer_id, 1, args.note or 'Initial version')
        conn.commit()
    print(json.dumps({'offer_code': offer_code, 'customer': customer['name'], 'project': args.project, 'version': 1}))


def cmd_offer_list(args):
    with connect() as conn:
        init_db(conn)
        q = """
        SELECT o.offer_code, c.name AS customer, o.project_id, o.title, o.status, o.currency, o.amount_total, o.current_version_no, o.updated_at
        FROM offers o JOIN customers c ON c.id = o.customer_id
        """
        where = []
        params = []
        if args.customer:
            where.append('(c.customer_code = ? OR c.name = ?)')
            params += [args.customer, args.customer]
        if args.project:
            where.append('o.project_id = ?')
            params.append(args.project)
        if args.status:
            where.append('o.status = ?')
            params.append(args.status)
        if where:
            q += ' WHERE ' + ' AND '.join(where)
        q += ' ORDER BY o.updated_at DESC LIMIT ?'
        params.append(args.limit)
        rows = [dict(r) for r in conn.execute(q, params)]
    print_rows(rows, table=args.table)


def cmd_offer_show(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        if args.version:
            row = conn.execute('SELECT version_no, change_summary, created_at, snapshot_json FROM offer_versions WHERE offer_id=? AND version_no=?', (offer['id'], args.version)).fetchone()
            if not row:
                raise ValueError('Version not found')
            out = dict(row)
            out['snapshot'] = json.loads(out.pop('snapshot_json'))
        else:
            out = dict(offer)
    print(json.dumps(out, indent=2, ensure_ascii=False))


def cmd_offer_versions(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        rows = [dict(r) for r in conn.execute('SELECT version_no, change_summary, created_at FROM offer_versions WHERE offer_id=? ORDER BY version_no DESC', (offer['id'],))]
    print_rows(rows, table=args.table)


def cmd_offer_status(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        conn.execute('UPDATE offers SET status=?, decision_at=? WHERE id=?', (args.status, args.decision_at, offer['id']))
        conn.commit()
    print(json.dumps({'offer': args.offer, 'status': args.status}))


def cmd_offer_revise(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        previous_version = int(offer['current_version_no'])
        new_version = previous_version + 1
        conn.execute(
            """
            UPDATE offers SET title=?, status='revised', currency=?, amount_subtotal=?, amount_tax=?, amount_total=?, valid_until=?, summary=?, assumptions=?, current_version_no=?
            WHERE id=?
            """,
            (
                args.title if args.title is not None else offer['title'],
                args.currency if args.currency is not None else offer['currency'],
                args.subtotal if args.subtotal is not None else offer['amount_subtotal'],
                args.tax if args.tax is not None else offer['amount_tax'],
                args.total if args.total is not None else offer['amount_total'],
                args.valid_until if args.valid_until is not None else offer['valid_until'],
                args.summary if args.summary is not None else offer['summary'],
                args.assumptions if args.assumptions is not None else offer['assumptions'],
                new_version,
                offer['id'],
            ),
        )
        prev_items = conn.execute('SELECT billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order FROM offer_line_items WHERE offer_id=? AND version_no=? ORDER BY sort_order, id', (offer['id'], previous_version)).fetchall()
        for item in prev_items:
            conn.execute(
                'INSERT INTO offer_line_items(offer_id, version_no, billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
                (offer['id'], new_version, item['billing_type'], item['name'], item['description'], item['quantity'], item['unit'], item['unit_price'], item['tax_rate'], item['line_subtotal'], item['line_tax'], item['line_total'], item['currency'], item['sort_order']),
            )
        recalc_offer_totals(conn, offer['id'], new_version)
        write_offer_version(conn, offer['id'], new_version, args.note or 'Offer revised')
        conn.commit()
    print(json.dumps({'offer': args.offer, 'version': new_version}))


def cmd_offer_item_add(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        version_no = args.version or int(offer['current_version_no'])
        subtotal, tax, total = calc_line_totals(args.quantity, args.unit_price, args.tax_rate)
        currency = args.currency or offer['currency']
        cur = conn.execute(
            'INSERT INTO offer_line_items(offer_id, version_no, billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
            (offer['id'], version_no, args.billing_type, args.name, args.description, args.quantity, args.unit, args.unit_price, args.tax_rate, subtotal, tax, total, currency, args.sort_order),
        )
        rs, rt, rg = recalc_offer_totals(conn, offer['id'], version_no)
        conn.commit()
    print(json.dumps({'ok': True, 'item_id': cur.lastrowid, 'offer': args.offer, 'version': version_no, 'line_total': total, 'offer_totals': {'subtotal': rs, 'tax': rt, 'total': rg}}))


def cmd_offer_item_list(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        version_no = args.version or int(offer['current_version_no'])
        rows = [dict(r) for r in conn.execute(
            'SELECT id, version_no, billing_type, name, description, quantity, unit, unit_price, tax_rate, line_subtotal, line_tax, line_total, currency, sort_order FROM offer_line_items WHERE offer_id=? AND version_no=? ORDER BY billing_type, sort_order, id',
            (offer['id'], version_no),
        )]
    print_rows(rows, table=args.table)


def cmd_offer_item_update(args):
    with connect() as conn:
        init_db(conn)
        row = conn.execute('SELECT * FROM offer_line_items WHERE id=?', (args.item_id,)).fetchone()
        if not row:
            raise ValueError('Item not found')
        quantity = args.quantity if args.quantity is not None else row['quantity']
        unit_price = args.unit_price if args.unit_price is not None else row['unit_price']
        tax_rate = args.tax_rate if args.tax_rate is not None else row['tax_rate']
        subtotal, tax, total = calc_line_totals(float(quantity), float(unit_price), float(tax_rate) if tax_rate is not None else None)
        conn.execute(
            'UPDATE offer_line_items SET billing_type=?, name=?, description=?, quantity=?, unit=?, unit_price=?, tax_rate=?, line_subtotal=?, line_tax=?, line_total=?, sort_order=? WHERE id=?',
            (
                args.billing_type or row['billing_type'],
                args.name or row['name'],
                args.description if args.description is not None else row['description'],
                quantity,
                args.unit if args.unit is not None else row['unit'],
                unit_price,
                tax_rate,
                subtotal,
                tax,
                total,
                args.sort_order if args.sort_order is not None else row['sort_order'],
                args.item_id,
            ),
        )
        rs, rt, rg = recalc_offer_totals(conn, row['offer_id'], row['version_no'])
        conn.commit()
    print(json.dumps({'ok': True, 'item_id': args.item_id, 'line_total': total, 'offer_totals': {'subtotal': rs, 'tax': rt, 'total': rg}}))


def cmd_offer_item_remove(args):
    with connect() as conn:
        init_db(conn)
        row = conn.execute('SELECT offer_id, version_no FROM offer_line_items WHERE id=?', (args.item_id,)).fetchone()
        if not row:
            raise ValueError('Item not found')
        conn.execute('DELETE FROM offer_line_items WHERE id=?', (args.item_id,))
        rs, rt, rg = recalc_offer_totals(conn, row['offer_id'], row['version_no'])
        conn.commit()
    print(json.dumps({'ok': True, 'item_id': args.item_id, 'offer_totals': {'subtotal': rs, 'tax': rt, 'total': rg}}))


def cmd_offer_totals_recalc(args):
    with connect() as conn:
        init_db(conn)
        offer = require_offer(conn, args.offer)
        version_no = args.version or int(offer['current_version_no'])
        rs, rt, rg = recalc_offer_totals(conn, offer['id'], version_no)
        conn.commit()
    print(json.dumps({'ok': True, 'offer': args.offer, 'version': version_no, 'subtotal': rs, 'tax': rt, 'total': rg}))


def cmd_search(args):
    with connect() as conn:
        init_db(conn)
        like = f"%{args.keyword}%"
        rows = []
        for r in conn.execute('SELECT customer_code AS ref, name AS label, "customer" AS entity, updated_at AS at FROM customers WHERE name LIKE ? OR notes LIKE ? LIMIT 20', (like, like)):
            rows.append(dict(r))
        for r in conn.execute('SELECT id AS ref, title AS label, "project" AS entity, updated_at AS at FROM projects WHERE title LIKE ? OR objective LIKE ? OR summary LIKE ? LIMIT 20', (like, like, like)):
            rows.append(dict(r))
        for r in conn.execute('SELECT offer_code AS ref, title AS label, "offer" AS entity, updated_at AS at FROM offers WHERE title LIKE ? OR summary LIKE ? OR assumptions LIKE ? LIMIT 20', (like, like, like)):
            rows.append(dict(r))
        for r in conn.execute('SELECT a.id AS ref, COALESCE(a.subject, substr(a.body,1,80)) AS label, "activity" AS entity, a.happened_at AS at FROM activities a WHERE a.subject LIKE ? OR a.body LIKE ? LIMIT 20', (like, like)):
            rows.append(dict(r))
    rows.sort(key=lambda x: (x.get('at') or ''), reverse=True)
    print_rows(rows[:args.limit], table=args.table)


def build_parser():
